@page "/railcartrips"
@using Railcar_Trips.Data
@using Railcar_Trips.Data.Models
@rendermode InteractiveServer
@inject RailcarTripsDbContext context

<PageTitle>Railcar Trips</PageTitle>

<h1>Upload Railcar or Equipment CSV file</h1>

@* Must be csv file *@
<InputFile OnChange="ReadCsv" accept=".csv" class="form-control" />

<p />

<h1>Grid</h1>

<p>This component demonstrates showing data.</p>

@*if (forecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
